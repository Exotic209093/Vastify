# API server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# SQLite metadata DB path (relative to api/ cwd)
DB_PATH=./vastify.db

# ───────────────────────────────────────────────────────────────
# Object backends — at least one must be enabled
# ───────────────────────────────────────────────────────────────

# MinIO (local dev; matches docker-compose.yml)
MINIO_ENABLED=true
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=vastify
MINIO_SECRET_KEY=vastifydev
MINIO_BUCKET=vastify-demo
MINIO_REGION=us-east-1

# Google Cloud Storage (demo target)
GCS_ENABLED=false
GCS_BUCKET=vastify-demo
GCS_PROJECT_ID=
# Path to service-account JSON, OR leave empty to use ADC
GOOGLE_APPLICATION_CREDENTIALS=

# AWS S3 (wired, not demoed)
S3_ENABLED=false
S3_BUCKET=vastify-demo
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure Blob (wired, not demoed)
AZURE_ENABLED=false
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=vastify-demo

# ───────────────────────────────────────────────────────────────
# Demo / seed
# ───────────────────────────────────────────────────────────────

DEMO_TENANT_ID=demo
DEMO_TENANT_API_KEY=vastify_demo_key_change_me

# Presigned URL TTL (seconds) — 24h default
PRESIGN_TTL_SEC=86400

# Demo-only: let Salesforce Connect hit /odata/v1/* without an API key, using the demo tenant.
# Never enable in production — this is a public-tenant shortcut for the hackathon demo.
VASTIFY_DEMO_PUBLIC_ODATA=true

# ───────────────────────────────────────────────────────────────
# Backup subsystem
# ───────────────────────────────────────────────────────────────

BACKUP_GIT_DATA_DIR=./.vastify/git
# Generate with: openssl rand -hex 32
VAULT_MASTER_KEY=<hex-encoded 32 bytes>
SF_CLIENT_ID=
SF_CLIENT_SECRET=
HS_CLIENT_ID=
HS_CLIENT_SECRET=

# ───────────────────────────────────────────────────────────────
# AI features (Setup Agent + Diff Explainer)
# ───────────────────────────────────────────────────────────────

# Required for /v1/agents/* routes. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Override only if you know what you're doing — Opus 4.7 is the demo target.
ANTHROPIC_MODEL=claude-opus-4-7
